{
  "name": "field-service-monorepo",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "build": "turbo build",
    "dev:all": "node ./scripts/start-web-and-mobile.mjs",
    "lint": "eslint apps/web apps/mobile packages/db packages/shared-types",
    "lint:turbo": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "db:migrate": "pnpm --filter @field-service/db migrate",
    "db:seed": "pnpm --filter @field-service/db db:seed",
    "approve-builds": "pnpm approve-builds --global sharp sqlite3 better-sqlite3 esbuild supabase unrs-resolver",
    "demo:reset": "tsx scripts/reset-supabase.ts",
    "mobile:metro:usb": "node ./scripts/start-mobile-metro-usb.mjs",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "setup": "pnpm approve-builds && pnpm install && pnpm demo:reset",
    "guard:stylesheet": "turbo guard:stylesheet",
    "guard:stylesheet:update-baseline": "pnpm --filter field-service-mobile guard:stylesheet:update-baseline",
    "test:shared": "pnpm run test:shared-types && pnpm run test:db",
    "test:shared-types": "pnpm --filter @field-service/shared-types test",
    "test:db": "pnpm --filter @field-service/db test",
    "test:mobile:unit": "pnpm run test:mobile:validators && pnpm run test:mobile:repositories && pnpm run test:mobile:sync && pnpm run test:mobile:hooks && pnpm run test:mobile:utils",
    "test:mobile:validators": "pnpm --filter field-service-mobile vitest run lib/validators/__tests__",
    "test:mobile:repositories": "pnpm --filter field-service-mobile vitest run lib/db/__tests__",
    "test:mobile:sync": "pnpm --filter field-service-mobile vitest run lib/sync/__tests__",
    "test:mobile:hooks": "pnpm --filter field-service-mobile vitest run lib/hooks/__tests__",
    "test:mobile:utils": "pnpm --filter field-service-mobile vitest run lib/utils/__tests__",
    "test:web:unit": "pnpm run test:web:lib && pnpm run test:web:api",
    "test:web:lib": "pnpm --filter field-service-web vitest run lib/__tests__",
    "test:web:realtime": "pnpm run test:web:lib",
    "test:web:hooks": "pnpm run test:web:lib",
    "test:web:api": "pnpm --filter field-service-web vitest run app/api",
    "test:unit": "pnpm run test:shared && pnpm run test:mobile:unit && pnpm run test:web:unit",
    "test:integration": "pnpm run test:integration:mobile && pnpm run test:integration:web",
    "test:integration:mobile": "pnpm --filter field-service-mobile vitest run __tests__/integration",
    "test:integration:web": "pnpm --filter field-service-web vitest run __tests__/integration",
    "test:e2e": "pnpm run test:e2e:mobile && pnpm run test:e2e:web",
    "test:e2e:mobile": "echo 'Run Maestro tests: maestro test e2e/maestro/mobile-*.yaml'",
    "test:e2e:web": "playwright test",
    "test:all": "pnpm run test:unit && pnpm run test:integration && pnpm run test:e2e"
  },
  "devDependencies": {
    "@eslint/js": "^9.26.0",
    "@expo/metro-runtime": "~6.1.2",
    "@testing-library/react": "^16.3.2",
    "@testing-library/react-native": "13.3.3",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "eslint": "^9.26.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-native": "^5.0.0",
    "prettier": "^3.3.3",
    "react-native-web": "^0.21.2",
    "react-test-renderer": "19.1.0",
    "turbo": "^2.9.4",
    "typescript": "~5.9.2"
  },
  "packageManager": "pnpm@10.28.1",
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@sentry/nextjs": "^10.47.0",
    "@sentry/react": "^10.47.0",
    "@supabase/ssr": "^0.10.0",
    "class-variance-authority": "^0.7.1",
    "lucide-react": "^1.7.0",
    "next": "^16.2.2"
  }
}
