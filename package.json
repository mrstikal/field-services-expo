{
  "name": "field-service-monorepo",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "build": "turbo build",
    "dev:all": "node ./scripts/start-web-and-mobile.mjs",
    "lint": "eslint apps/web apps/mobile packages/db packages/shared-types",
    "lint:turbo": "turbo lint",
    "typecheck": "turbo typecheck && tsc --noEmit --project tsconfig.e2e.json",
    "test": "turbo test",
    "db:migrate": "pnpm --filter @field-service/db migrate",
    "db:seed": "pnpm --filter @field-service/db db:seed",
    "approve-builds": "pnpm approve-builds --global sharp sqlite3 better-sqlite3 esbuild supabase unrs-resolver",
    "demo:reset": "node ./scripts/reset-supabase.mjs",
    "mobile:metro:usb": "node ./scripts/start-mobile-metro-usb.mjs",
    "imports:shorten": "node ./scripts/shorten-imports.mjs",
    "imports:shorten:check": "node ./scripts/shorten-imports.mjs --check",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "setup": "pnpm approve-builds && pnpm install && pnpm demo:reset",
    "guard:stylesheet": "turbo guard:stylesheet",
    "guard:stylesheet:update-baseline": "pnpm --filter field-service-mobile guard:stylesheet:update-baseline",
    "test:shared": "pnpm --filter @field-service/shared-types test && pnpm --filter @field-service/db test",
    "test:unit": "pnpm run test:shared && pnpm --filter field-service-mobile vitest run lib/validators/__tests__ lib/db/__tests__ lib/sync/__tests__ lib/hooks/__tests__ lib/utils/__tests__ && pnpm --filter field-service-web vitest run lib/__tests__ app/api/__tests__",
    "test:integration": "pnpm --filter field-service-mobile vitest run __tests__/integration && pnpm --filter field-service-web vitest run __tests__/integration",
    "test:e2e": "pnpm run test:e2e:web",
    "test:e2e:web": "playwright test",
    "test:e2e:web:reset": "node ./scripts/run-playwright-with-reset.mjs",
    "test:e2e:mobile": "node ./scripts/run-maestro-tests.mjs",
    "test:e2e:mobile:emulator": "node ./scripts/run-maestro-tests-emulator.mjs",
    "test:e2e:full": "pnpm run test:e2e:mobile && pnpm run test:e2e:web",
    "test:all": "pnpm run test:unit && pnpm run test:integration && pnpm run test:e2e"
  },
  "devDependencies": {
    "@eslint/js": "^9.26.0",
    "@expo/metro-runtime": "~6.1.2",
    "@playwright/test": "1.59.1",
    "@supabase/supabase-js": "2.101.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/react-native": "13.3.3",
    "@types/node": "^25.5.2",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "dotenv": "^17.4.1",
    "eslint": "^9.26.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-native": "^5.0.0",
    "prettier": "^3.3.3",
    "react-native-web": "^0.21.2",
    "react-test-renderer": "19.1.0",
    "turbo": "^2.9.4",
    "typescript": "~5.9.2"
  },
  "packageManager": "pnpm@10.28.1",
  "dependencies": {}
}
