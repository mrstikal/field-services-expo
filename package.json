{
  "name": "field-service-monorepo",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "eslint apps/web apps/mobile packages/db packages/shared-types",
    "lint:turbo": "turbo lint",
    "typecheck": "turbo typecheck",
    "db:migrate": "pnpm --filter @field-service/db migrate",
    "db:seed": "pnpm --filter @field-service/db db:seed",
    "approve-builds": "pnpm approve-builds --global sharp sqlite3 better-sqlite3 esbuild supabase unrs-resolver",
    "demo:reset": "tsx scripts/reset-supabase.ts",
    "mobile:metro:usb": "node -e \"require('child_process').spawnSync(process.platform === 'win32' ? 'powershell' : 'bash', [process.platform === 'win32' ? './scripts/start-mobile-metro-usb.ps1' : './scripts/start-mobile-metro-usb.sh'], {stdio: 'inherit', cwd: process.cwd()})\"",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "setup": "pnpm approve-builds && pnpm install && pnpm demo:reset",
    "guard:stylesheet": "turbo guard:stylesheet",
    "guard:stylesheet:update-baseline": "pnpm --filter field-service-mobile guard:stylesheet:update-baseline"
  },
  "devDependencies": {
    "@eslint/js": "^9.26.0",
    "@expo/metro-runtime": "~6.1.2",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "eslint": "^9.26.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-native": "^5.0.0",
    "prettier": "^3.3.3",
    "react-native-web": "^0.21.2",
    "turbo": "^2.9.4",
    "typescript": "^6.0.2"
  },
  "packageManager": "pnpm@10.28.1",
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@react-native-picker/picker": "^2.11.4",
    "@sentry/nextjs": "^10.47.0",
    "@sentry/react": "^10.47.0",
    "@sentry/react-native": "^8.7.0",
    "@supabase/ssr": "^0.10.0",
    "class-variance-authority": "^0.7.1",
    "expo-image": "^55.0.8",
    "lucide-react": "^1.7.0",
    "next": "^16.2.2",
    "react-native-picker-select": "^9.3.1"
  }
}
