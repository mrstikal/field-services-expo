{
  "name": "field-service-monorepo",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "eslint apps/web apps/mobile packages/db packages/shared-types",
    "lint:turbo": "turbo lint",
    "typecheck": "turbo typecheck",
    "db:seed": "pnpm --filter @field-service/db db:seed",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "setup": "pnpm install && pnpm --filter @field-service/db db:seed",
    "guard:stylesheet": "turbo guard:stylesheet",
    "guard:stylesheet:update-baseline": "pnpm --filter field-service-mobile guard:stylesheet:update-baseline"
  },
  "devDependencies": {
    "@eslint/js": "^9.26.0",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "eslint": "^9.26.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-native": "^5.0.0",
    "prettier": "^3.3.3",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "packageManager": "pnpm@10.28.1",
  "pnpm": {
    "overrides": {
      "react": "^19.0.0",
      "react-dom": "^19.0.0",
      "@types/react": "^18.3.0"
    }
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@supabase/auth-helpers-nextjs": "^0.15.0",
    "@supabase/ssr": "^0.10.0",
    "class-variance-authority": "^0.7.1",
    "lucide-react": "^1.7.0",
    "next": "^16.2.2"
  }
}