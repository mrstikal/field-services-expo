# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
# NOTE:
# Do not commit server-side secrets (SUPABASE_SERVICE_KEY, private API keys)
# into shared env templates. Keep them only in app-specific local env files.

# Mapbox Configuration (Optional - for dispatcher map)
MAPBOX_TOKEN=your-mapbox-token-here

# Sentry Configuration (Optional - for error tracking)
SENTRY_DSN=your-sentry-dsn-here

# App Configuration
EXPO_PUBLIC_APP_NAME=Field Service
EXPO_PUBLIC_API_URL=http://localhost:3000
EXPO_PUBLIC_EAS_PROJECT_ID=your-eas-project-id-here

# Supabase S3 Storage Configuration (for file uploads)
SUPABASE_S3_ENDPOINT=https://your-project.storage.supabase.co/storage/v1/s3
SUPABASE_S3_ACCESS_KEY_ID=your-s3-access-key-id
SUPABASE_S3_SECRET_ACCESS_KEY=your-s3-secret-access-key
SUPABASE_S3_BUCKET=report-assets
SUPABASE_S3_REGION=auto

# Database Configuration (for local development)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/field_service
