# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_KEY=your-service-key-here
SUPABASE_DB_PASSWORD=your-db-password-here

# Next.js Public Supabase (for web app)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Expo Public Supabase (for mobile app)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Database Configuration (Supabase Postgres)
DATABASE_URL=postgresql://postgres:your-db-password-here@db.your-project.supabase.co:5432/postgres

# Mapbox
MAPBOX_TOKEN=your-mapbox-token-here
NEXT_PUBLIC_MAPBOX_TOKEN=your-mapbox-token-here

# Sentry
SENTRY_DSN=your-sentry-dsn

# App Config
EXPO_PUBLIC_APP_NAME=Field Service
EXPO_PUBLIC_API_URL=http://localhost:3000
EXPO_PUBLIC_GOOGLE_CLOUD_API_KEY=your-google-cloud-api-key-here
