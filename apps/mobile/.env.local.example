# Supabase Public Keys (Expo)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# App Config
EXPO_PUBLIC_APP_NAME=Field Service
EXPO_PUBLIC_API_URL=http://localhost:3000

# Supabase S3 Storage Configuration
EXPO_PUBLIC_SUPABASE_S3_ENDPOINT=https://your-project.storage.supabase.co/storage/v1/s3
EXPO_PUBLIC_SUPABASE_S3_ACCESS_KEY_ID=your-s3-access-key-id
EXPO_PUBLIC_SUPABASE_S3_SECRET_ACCESS_KEY=your-s3-secret-access-key
EXPO_PUBLIC_SUPABASE_S3_BUCKET=FieldService

# Sentry Configuration
EXPO_PUBLIC_SENTRY_DSN=your-sentry-dsn-here