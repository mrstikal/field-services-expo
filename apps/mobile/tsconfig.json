{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "ignoreDeprecations": "6.0",
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./*"
      ],
      "@lib/*": [
        "./lib/*"
      ],
      "@shared/*": [
        "../../packages/shared-types/*"
      ]
    },
    "moduleResolution": "bundler",
    "skipLibCheck": true,
    "noEmit": true,
    "types": [
      "nativewind/types",
      "vitest"
    ]
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "**/*.d.ts",
    "nativewind-env.d.ts",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ],
  "exclude": [
    "node_modules",
    "../web/**/*"
  ]
}
